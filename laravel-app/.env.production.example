APP_NAME="Pollos y Parrillas El Dorado"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.tudominio.com

# Si tu web y tu API estan en dominios distintos, define aqui la base de la API.
# Ejemplo: API_BASE_URL=https://api.tudominio.com
API_BASE_URL=

APP_TIMEZONE=America/Lima

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pollos_el_dorado
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.tudominio.com

BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT=25

COMPANY_HOURS="11:00 a. m. a 10:00 p. m."

# CORS (pon aquí el/los dominios reales de tu web y/o Flutter Web)
# Ejemplo: CORS_ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com
CORS_ALLOWED_ORIGINS=
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.tuproveedor.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=ventas@tudominio.com
MAIL_FROM_NAME="${APP_NAME}"

COMPANY_BRAND_NAME="Pollos y Parrillas El Dorado"
COMPANY_LEGAL_NAME="Pollos y Parrillas El Dorado S.A.C."
COMPANY_RUC=20123456789
COMPANY_SUPPORT_PHONE=999888777
COMPANY_SUPPORT_EMAIL=ventas@tudominio.com
COMPANY_CURRENCY=PEN

COMPANY_YAPE_LABEL="Yape Empresa"
COMPANY_YAPE_PHONE=999888777
COMPANY_YAPE_QR_PATH=/images/yape-qr.png
COMPANY_YAPE_ENABLED=true

COMPANY_PLIN_LABEL="Plin Empresa"
COMPANY_PLIN_PHONE=999888777
COMPANY_PLIN_QR_PATH=/images/plin-qr.png
COMPANY_PLIN_ENABLED=true

COMPANY_TRANSFER_LABEL="Transferencia bancaria"
COMPANY_BANK_NAME=BCP
COMPANY_BANK_ACCOUNT=123-4567890-12
COMPANY_BANK_CCI=00212300456789012345
COMPANY_BANK_ACCOUNT_HOLDER="Pollos y Parrillas El Dorado S.A.C."
COMPANY_TRANSFER_ENABLED=true

COMPANY_COD_LABEL="Pago contraentrega"
COMPANY_COD_MESSAGE="Pagas cuando recibes tu pedido."
COMPANY_COD_ENABLED=true

COMPANY_CULQI_LABEL="Culqi"
COMPANY_CULQI_ENABLED=true

APISPERU_DNIRUC_BASE_URL=https://dniruc.apisperu.com/api/v1
APISPERU_DNIRUC_TOKEN=
APISPERU_DNIRUC_AUTH_MODE=query
APISPERU_DNIRUC_TOKEN_QUERY_PARAM=token
APISPERU_DNIRUC_TIMEOUT=15

# RENIEC: define la URL exacta del proveedor contratado o del servicio con convenio.
# Usa {dni} como placeholder para el documento.
RENIEC_LOOKUP_URL=https://dniruc.apisperu.com/api/v1/dni/{numero}
RENIEC_API_TOKEN=
RENIEC_AUTH_MODE=query
RENIEC_TOKEN_QUERY_PARAM=token
RENIEC_TIMEOUT=15

# SUNAT: si ya tienes token fijo, usa SUNAT_API_TOKEN.
# Si usas OAuth SUNAT, normalmente completa SUNAT_TOKEN_URL, SUNAT_CLIENT_ID,
# SUNAT_CLIENT_SECRET, SUNAT_SCOPE, SUNAT_USERNAME y SUNAT_PASSWORD.
# Usa {ruc} como placeholder para la consulta.
SUNAT_LOOKUP_URL=https://dniruc.apisperu.com/api/v1/ruc/{numero}
SUNAT_API_TOKEN=
SUNAT_AUTH_MODE=query
SUNAT_TOKEN_QUERY_PARAM=token
SUNAT_TOKEN_URL=
SUNAT_GRANT_TYPE=password
SUNAT_CLIENT_ID=
SUNAT_CLIENT_SECRET=
SUNAT_SCOPE=
SUNAT_USERNAME=
SUNAT_PASSWORD=
SUNAT_TIMEOUT=15

CULQI_ENABLED=true
CULQI_REFERENCE_ONLY=true
CULQI_MODE=test
CULQI_PUBLIC_KEY=pk_test_xxxxxxxxx
CULQI_SECRET_KEY=sk_test_xxxxxxxxx
CULQI_RSA_ID=
CULQI_RSA_PUBLIC_KEY=

EINVOICE_PROVIDER=apisperu
EINVOICE_ENVIRONMENT=produccion
EINVOICE_CURRENCY=PEN
EINVOICE_BOLETA_SERIES=B001
EINVOICE_FACTURA_SERIES=F001
COMPANY_FISCAL_ADDRESS="Av. Principal 123"
COMPANY_FISCAL_DEPARTMENT=LIMA
COMPANY_FISCAL_PROVINCE=LIMA
COMPANY_FISCAL_DISTRICT=LIMA
COMPANY_FISCAL_UBIGEO=150101
COMPANY_FISCAL_COUNTRY_CODE=PE
COMPANY_FISCAL_LOCAL_CODE=0000

APISPERU_FACT_BASE_URL=https://facturacion.apisperu.com/api/v1
APISPERU_FACT_COMPANY_TOKEN=
APISPERU_FACT_USERNAME=
APISPERU_FACT_PASSWORD=
APISPERU_FACT_TIMEOUT=30
