APP_NAME="Pollos y Parrillas El Dorado"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Opcional: si el frontend corre en otro dominio y consume esta API.
# Ejemplo: API_BASE_URL=http://localhost
API_BASE_URL=

APP_TIMEZONE=America/Lima

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=app_pollos_el_dorado
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_PATH=
FCM_SERVICE_ACCOUNT_JSON=

OPENAI_API_KEY=sk-...EcEA
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT=25

COMPANY_HOURS="11:00 a. m. a 10:00 p. m."

# CORS (para Flutter Web / frontends en otro puerto/dominio)
# Ejemplo local: CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:56321
# Si lo dejas en "*" permite el Origin que llegue (solo recomendado en local).
CORS_ALLOWED_ORIGINS=*
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

COMPANY_BRAND_NAME="Pollos y Parrillas El Dorado"
COMPANY_LEGAL_NAME="Pollos y Parrillas El Dorado S.A.C."
